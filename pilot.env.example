# Live-pilot credentials — copy to pilot.env and fill in.
# pilot.env is gitignored; never commit it, never paste these values in chat.
# chukei itself never sees these: the test client sends them and chukei
# passes auth through verbatim (invariant #4).

# Account locator incl. region, e.g. abc12345.eu-west-2.aws — from your
# account URL https://<this-part>.snowflakecomputing.com
SNOWFLAKE_ACCOUNT=

SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# Trial accounts ship with COMPUTE_WH
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
